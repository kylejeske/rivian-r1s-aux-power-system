{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kylejeske/rivian-r1s-aux-power-system/schemas/component.schema.json",
  "title": "Component",
  "description": "A component record for the Rivian R1S modular auxiliary power system.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^C-[0-9]{4}$"
    },
    "name": {
      "type": "string"
    },
    "manufacturer": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "selected", "rejected", "deferred"]
    },
    "reason": {
      "type": "string"
    },
    "ratings": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  }
}
